{
  "name": "tree-sitter-kiwi",
  "private": true,
  "description": "Tree Sitter grammar for kiwi",
  "main": "./bindings/node",
  "types": "./bindings/node",
  "files": [
    "*.wasm",
    "binding.gyp",
    "bindings/node/*",
    "grammar.js",
    "prebuilds/**",
    "queries/*",
    "src/**",
    "tree-sitter.json"
  ],
  "scripts": {
    "tree-sitter": "tree-sitter",
    "postinstall": "node-gyp-build",
    "build": "prebuildify --napi --strip",
    "generate": "tree-sitter generate",
    "clean": "rimraf build prebuilds *.dylib *.wasm",
    "dev": "tree-sitter build --wasm && tree-sitter playground",
    "test": "tree-sitter test"
  },
  "peerDependencies": {
    "tree-sitter": "^0.22.4"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "dependencies": {
    "node-addon-api": "^8.6.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "prebuildify": "^6.0.1",
    "tree-sitter-cli": "^0.25.3"
  }
}
